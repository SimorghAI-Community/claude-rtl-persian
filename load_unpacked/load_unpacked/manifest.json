{
  "manifest_version": 3,
  "name": "راست‌نویس (RTL Fixer)",
  "version": "1.2.0",
  "description": "Smart real-time RTL layout and Persian font fixer for LLMs and professional networks.",
  "author": "Dash Mehrdad Aziz",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "contextMenus"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://*.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ]
}